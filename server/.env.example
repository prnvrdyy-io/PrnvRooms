MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/rtc-platform?retryWrites=true&w=majority
PORT=5000
NODE_ENV=development
JWT_SECRET=replace_this_with_a_long_random_secret_string_at_least_64_chars
JWT_REFRESH_SECRET=replace_this_with_another_long_random_secret_string_at_least_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
