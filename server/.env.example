MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority&appName=<AppName>
PORT=5000
NODE_ENV=development
JWT_SECRET=replace_with_64_char_random_hex_string
JWT_REFRESH_SECRET=replace_with_another_64_char_random_hex_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
