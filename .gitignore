# ─── Dependencies ─────────────────────────────────────────────
node_modules/

# ─── Environment variables (NEVER commit these) ───────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── Build outputs ────────────────────────────────────────────
dist/
build/
.next/

# ─── Uploaded files (stored locally during dev) ───────────────
server/uploads/*
!server/uploads/.gitkeep

# ─── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*

# ─── OS artifacts ─────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Editor / IDE ─────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ─── Vite cache ───────────────────────────────────────────────
.vite/
